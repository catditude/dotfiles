# Machine-specific shell config. Copy to ~/.zsh/local.zsh (not tracked).
# This file is auto-sourced by .zshrc via the ~/.zsh/*.zsh glob.

# --- Amazon / Brazil ---
# export BRAZIL_WORKSPACE_DEFAULT_LAYOUT=short
