[include]
	path = ~/.gitconfig.local

[core]
	editor = nvim
	pager = delta
	excludesFile = ~/.gitignore_global

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true
	dark = true
	syntax-theme = base16
	minus-style = syntax "#3a2a2a"
	minus-emph-style = syntax "#6b2a2a"
	plus-style = syntax "#2a3a2a"
	plus-emph-style = syntax "#2a5a2a"
	line-numbers = true
	line-numbers-minus-style = "#ff005f"
	line-numbers-plus-style = "#9EB294"
	line-numbers-zero-style = "#878787"
	hunk-header-style = file line-number syntax
	hunk-header-decoration-style = "#dfafff" ul
	context = 10

[merge]
	conflictStyle = zdiff3

[push]
	default = simple

[alias]
	dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)%an <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
