{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Task",
      "WebFetch",
      "WebSearch",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(RUST_LOG=info timeout 60 cargo run:*)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/tailor_cli status)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/pipeline diff --stat)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/pipeline log --oneline -3)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/tailor diff)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/tailor log --oneline -3)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/tailor status:*)",
      "Bash(git -C /home/di/workspace/ResumeTailorWorkspace/tailor diff --stat)",
      "Bash(cargo fmt:*)",
      "Bash(cargo clippy:*)",
      "mcp__plugin_linear_linear__get_issue",
      "mcp__plugin_linear_linear__list_issue_statuses",
      "Bash(cargo check:*)",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_linear_linear__list_teams",
      "Bash(rustc:*)",
      "mcp__plugin_linear_linear__list_issues",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(cargo run:*)"
    ],
    "defaultMode": "default"
  },
  "statusLine": {
    "type": "command",
    "command": "bunx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "linear@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true
  },
  "effortLevel": "high"
}
